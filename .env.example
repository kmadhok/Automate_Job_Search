# OpenAI API Key
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Optional Gmail/LinkedIn tuning
# GMAIL_LABEL=Linkedln Jobs
# MAX_EMAILS=5
# MAX_JOB_URLS=25
# GMAIL_QUERY_DAYS=14
# LINKEDIN_SENDERS=jobs-noreply@linkedin.com,jobalerts-noreply@linkedin.com,notifications-noreply@linkedin.com
# JOB_TAGS=data scientist,data engineer,ai engineer,data analyst
# GMAIL_QUERY=

# Optional auth/runtime paths for server deployments
# GMAIL_INTERACTIVE_AUTH=0
# CREDENTIALS_FILE=credentials.json
# TOKEN_FILE=token.json
# OUTPUT_DIR=output

# Optional people-search automation (for outreach target discovery)
# SERPER_DEV_API_KEY=your-serper-api-key-here
# SERPER_API_KEY=your-serper-api-key-here

# Required for cron-running the full daily pipeline wrapper
# COMPLETE_PIPELINE_SHEET=https://docs.google.com/spreadsheets/d/<id>/edit
# COMPLETE_PIPELINE_TRIGGER=run complete package
# COMPLETE_PIPELINE_NON_INTERACTIVE_SHEETS=1
# COMPLETE_PIPELINE_JOBS_TAB=jobs
# COMPLETE_PIPELINE_JOB_CONTACTS_TAB=job_contacts
# COMPLETE_PIPELINE_JOB_MESSAGES_TAB=job_messages
# COMPLETE_PIPELINE_RESUME_TAB=resume_tailoring
# COMPLETE_PIPELINE_NETWORKING_CONTACTS_TAB=networking_contacts
# COMPLETE_PIPELINE_NETWORKING_MESSAGES_TAB=networking_messages

# Optional profile summary added into generated outreach messages
# OUTREACH_PROFILE_SUMMARY=I am a data scientist with 5+ years building ML products...
# OUTREACH_RESUME_PDF=/absolute/path/to/your_resume.pdf

# Optional networking targeting defaults (used by find_networking_contacts.py and full pipeline)
# NETWORK_INTERNAL_COMPANIES=Walmart,Walmart Global Tech
# NETWORK_EXTERNAL_COMPANIES=Microsoft,Amazon,Meta,OpenAI,NVIDIA
# NETWORK_TITLE_TERMS=Data Scientist,AI Engineer,Machine Learning Engineer,Data Analyst,Applied Scientist
# NETWORK_KEYWORDS=agents,large language models,llm,applied ai,production ai,real-world ai
# NETWORK_FOCUS_TERMS=customer impact,supply chain,optimization,recommendation systems,automation
# NETWORK_PROFILE_SUMMARY=I work on applied ML/AI systems and would value learning from practitioners...

# Optional resume tailoring model override
# RESUME_TAILOR_MODEL=gpt-4o-mini
